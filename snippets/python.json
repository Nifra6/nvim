{
  "pylint_ignore_line": {
    "prefix": "#pylint",
    "body": ["# pylint: disable=${1:import-error}"],
    "description": "Add a pylint disable comment."
  },
  "pathify_str": {
    "prefix": "pathy",
    "body": ["${1:path} = Path(${1})"],
    "description": "Ensure a path is in pathlib."
  },
  "section": {
    "prefix": "section",
    "body": [
      "# ------------------------------------------------------------",
      "# ${1:SECTION}",
      "# ------------------------------------------------------------"
    ],
    "description": "Add a section delimitation."
  },
  "import_numpy": {
    "prefix": "np",
    "body": ["import numpy as np"],
    "description": "Import numpy with is classical alias."
  },
  "import_numpy_typing": {
    "prefix": "npt",
    "body": ["import numpy.typing as npt"],
    "description": "Import numpy.typing with is classical alias."
  },
  "import_imageio": {
    "prefix": "iio",
    "body": ["import imageio.v3 as iio"],
    "description": "Import imageio with is classical alias."
  },
  "import_rich_print": {
    "prefix": "rprint",
    "body": ["from rich import print as rich_print"],
    "description": "Import rich.print as rich_print."
  }
}
