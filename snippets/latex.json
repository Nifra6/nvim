{
  "ltex_magic_comment": {
    "prefix": "ltex",
    "body": ["% LTeX: ${1:enabled}=${2:false}"],
    "description": "Add a LTeX magic comment."
  },
  "ltex_language": {
    "prefix": "lang",
    "body": ["% LTeX: language=${1:fr}"],
    "description": "Add a LTeX magic comment to change the language checked."
  },
  "math_inline": {
    "prefix": "mi",
    "body": ["\\\\(${1:x}\\\\)"],
    "description": "Insert Math inline environment."
  },
  "left_and_right_parenthesis": {
    "prefix": "leftp",
    "body": ["\\left( ${1:x} \\right)"],
    "description": "Insert dynamic parenthesis."
  },
  "left_and_right_bracket": {
    "prefix": "leftb",
    "body": ["\\left[ ${1:x} \\right]"],
    "description": "Insert dynamic bracket."
  },
  "italicized_et_al": {
    "prefix": "etal",
    "body": ["\\textit{et al.}"],
    "description": "Insert an italicized 'et al.'."
  },
  "italicized_ie": {
    "prefix": "ie",
    "body": ["\\textit{i.e.}"],
    "description": "Insert an italicized 'i.e.'."
  },
  "italicized_eg": {
    "prefix": "eg",
    "body": ["\\textit{e.g.}"],
    "description": "Insert an italicized 'e.g.'."
  }
}
